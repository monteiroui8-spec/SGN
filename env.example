# ============================================================
# SGN — Sistema de Gestão de Notas · IPM Mayombe
# Copiar este ficheiro para .env e preencher os valores reais
# NUNCA commitar o .env no git
# ============================================================

# ─── Base de Dados ───────────────────────────────────────────
DB_HOST=localhost
DB_NAME=sgn_ipm
DB_USER=root
DB_PASS=

# ─── JWT ─────────────────────────────────────────────────────
# Gerar um segredo forte: openssl rand -hex 32
JWT_SECRET=ALTERAR_PARA_UM_VALOR_SECRETO_LONGO_E_ALEATORIO

# ─── Email (PHPMailer) ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=email@escola.ao
MAIL_PASS=senha_app_google
MAIL_FROM=noreply@escola.ao
MAIL_FROM_NAME="Gestão de Notas - IPM Mayombe"

# ─── App ─────────────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_ENV=development
